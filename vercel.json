{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    { "source": "/sales-tasks/api/:path*", "destination": "/api/:path*" },
    { "source": "/sales-tasks/assets/:path*", "destination": "/assets/:path*" },
    { "source": "/sales-tasks/favicon.svg", "destination": "/favicon.svg" },
    { "source": "/sales-tasks/:path*", "destination": "/index.html" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
