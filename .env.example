# Used by api/ serverless functions. Never expose these client-side.

# Direct Postgres via the pg driver — not the Supabase JS client (see
# design.md section 12, "Database access pattern"). Use the "Transaction
# pooler" connection string (Supabase -> Project Settings -> Database ->
# Connection Pooling -> mode "Transaction"), not the direct :5432 one —
# serverless functions need pooled connections. Locally this should point
# at the dev Supabase project, never the production one.
DATABASE_URL=

# Clerk dashboard -> API Keys -> Secret key
CLERK_SECRET_KEY=

# Optional, not read by app code. Only needed to curl/verify protected Vercel
# preview deployments from outside a browser (see Deployment Protection ->
# "Protection Bypass for Automation" in Vercel project settings). If this
# becomes a CI post-deploy smoke test (Milestone 9), it belongs as a GitHub
# Actions repo secret instead, not here.
VERCEL_PROTECTION_BYPASS_SECRET=
